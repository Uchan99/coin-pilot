# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coinpilot

# Redis Configuration (Week 3 Added)
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Agent Configuration
# LLM Provider Selection (default: anthropic)
LLM_PROVIDER=anthropic
LLM_MODE=dev
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic API Key (Required for MarketAnalyst & RiskGuardian)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API Key (Optional - Alternative LLM Provider)
# To use OpenAI instead of Anthropic:
# 1. Set LLM_PROVIDER=openai
# 2. Add langchain-openai to requirements.txt
# OPENAI_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# AI Decision Canary (Analyst/Guardian only)
AI_DECISION_PRIMARY_PROVIDER=anthropic
AI_DECISION_PRIMARY_MODEL=claude-haiku-4-5-20251001
AI_CANARY_ENABLED=false
AI_CANARY_PROVIDER=openai
AI_CANARY_MODEL=gpt-4o-mini
AI_CANARY_PERCENT=10
LLM_USAGE_ENABLED=true
# Optional: 모델 단가 override (USD per 1M tokens)
# 예시:
# LLM_USAGE_PRICE_TABLE_JSON={"anthropic:claude-haiku-4-5-20251001":{"input_per_1m":0.8,"output_per_1m":4.0},"openai:gpt-4o-mini":{"input_per_1m":0.15,"output_per_1m":0.6}}
LLM_USAGE_PRICE_TABLE_JSON=
# Optional: provider 구간 비용 스냅샷 자동 수집 (Phase 2.1)
# - URL template/value path/headers가 모두 설정된 provider만 수집됩니다.
# - URL template placeholder:
#   ${START_UNIX}, ${END_UNIX}, ${START_ISO}, ${END_ISO}
# - headers JSON에서 ${ENV_NAME} placeholder를 사용할 수 있습니다.
#   예: {"Authorization":"Bearer ${OPENAI_ADMIN_KEY}"}
LLM_COST_SNAPSHOT_ENABLED=false
LLM_COST_SNAPSHOT_INTERVAL_MIN=60
LLM_COST_SNAPSHOT_LOOKBACK_HOURS=1
LLM_COST_SNAPSHOT_PROVIDERS=anthropic,openai
LLM_COST_SNAPSHOT_ANTHROPIC_URL_TEMPLATE=
LLM_COST_SNAPSHOT_ANTHROPIC_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_ANTHROPIC_HEADERS_JSON=
LLM_COST_SNAPSHOT_OPENAI_URL_TEMPLATE=
LLM_COST_SNAPSHOT_OPENAI_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_OPENAI_HEADERS_JSON=

# Optional: cAdvisor 라벨 공백 환경 대응용 컨테이너 서비스명 매핑 주기(초)
CONTAINER_MAP_INTERVAL_SEC=30

# Paper Trading
PAPER_BALANCE=10000000
BOT_HOST=127.0.0.1
BOT_PORT=8000

# RSS News (Phase 4B - RSS Only)
# 쉼표로 여러 피드를 지정합니다.
NEWS_RSS_SOURCES=https://cointelegraph.com/rss,https://www.coindesk.com/arc/outboundfeeds/rss/,https://decrypt.co/feed
NEWS_RSS_INGEST_INTERVAL_MIN=10
NEWS_RSS_SUMMARY_INTERVAL_MIN=30
NEWS_RSS_TIMEOUT_SECONDS=12
NEWS_RISK_WINDOW_HOURS=6
NEWS_MAX_ARTICLES_PER_SYMBOL=80

# Chatbot Phase 5 Guardrails
CHAT_SESSION_COOLDOWN_SECONDS=1.5
CHAT_CACHE_TTL_SECONDS=300
CHAT_CACHE_MAX_ENTRIES=256
CHAT_MAX_INPUT_CHARS=600
CHAT_MAX_OUTPUT_CHARS=2200
CHAT_ENABLE_PREMIUM_REVIEW=true
CHAT_PREMIUM_REVIEW_MIN_QUERY_LEN=28
CHAT_PREMIUM_REVIEW_TIMEOUT_SEC=12
# Optional: override premium review model (default: Sonnet)
LLM_PREMIUM_MODEL=claude-sonnet-4-5-20250929
