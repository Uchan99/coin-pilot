# Optional: provider 구간 비용 스냅샷 자동 수집 (Phase 2.2)
# - 기본값은 비활성이다. 개인 계정 기준으로는 OpenAI/Anthropic 모두
#   org/admin 비용 API 접근 권한이 없는 경우가 많다.
# - OpenAI: organization admin key(예: OPENAI_ADMIN_KEY) 권한이 있을 때만 권장
# - Anthropic: Admin API key(예: ANTHROPIC_ADMIN_API_KEY) + 조직 계정이 있을 때만 권장
# - URL template/value path/headers가 모두 설정된 provider만 수집된다.
# - URL template placeholder:
#   ${START_UNIX}, ${END_UNIX}, ${START_ISO}, ${END_ISO}
# - headers JSON에서 ${ENV_NAME} placeholder를 사용할 수 있다.
#   예: {"Authorization":"Bearer ${OPENAI_ADMIN_KEY}"}
# - 공식 비용 API는 일 단위 bucket이 기본이므로 24h/1440분 설정을 권장한다.
LLM_COST_SNAPSHOT_ENABLED=false
LLM_COST_SNAPSHOT_INTERVAL_MIN=1440
LLM_COST_SNAPSHOT_LOOKBACK_HOURS=24
LLM_COST_SNAPSHOT_PROVIDERS=anthropic,openai
# Personal account 기본 운영: disabled 유지 + 아래 값 공란 유지
# Organization/Admin 권한 확보 후에만 채운다.
LLM_COST_SNAPSHOT_ANTHROPIC_URL_TEMPLATE=
LLM_COST_SNAPSHOT_ANTHROPIC_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_ANTHROPIC_HEADERS_JSON=
LLM_COST_SNAPSHOT_ANTHROPIC_METHOD=GET
LLM_COST_SNAPSHOT_ANTHROPIC_BODY_TEMPLATE=
LLM_COST_SNAPSHOT_ANTHROPIC_ITEMS_JSON_PATH=
LLM_COST_SNAPSHOT_ANTHROPIC_ITEM_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_ANTHROPIC_VALUE_DIVISOR=100
LLM_COST_SNAPSHOT_OPENAI_URL_TEMPLATE=
LLM_COST_SNAPSHOT_OPENAI_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_OPENAI_HEADERS_JSON=
LLM_COST_SNAPSHOT_OPENAI_METHOD=GET
LLM_COST_SNAPSHOT_OPENAI_BODY_TEMPLATE=
LLM_COST_SNAPSHOT_OPENAI_ITEMS_JSON_PATH=
LLM_COST_SNAPSHOT_OPENAI_ITEM_VALUE_JSON_PATH=
LLM_COST_SNAPSHOT_OPENAI_VALUE_DIVISOR=1

# Optional: cAdvisor 라벨 공백 환경 대응용 컨테이너 서비스명 매핑 주기(초)
CONTAINER_MAP_INTERVAL_SEC=30

# Optional: Promtail docker_sd API 버전 (Docker Engine 최소 지원 버전과 일치 필요)
PROMTAIL_DOCKER_API_VERSION=1.44

# Optional: Promtail 로그 타깃 symlink 갱신 주기(초)
PROMTAIL_TARGET_INTERVAL_SEC=30
