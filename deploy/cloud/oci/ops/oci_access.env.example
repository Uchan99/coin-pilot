# CoinPilot OCI access standard example
# 복사 후 실제 값으로 채우세요:
#   cp deploy/cloud/oci/ops/oci_access.env.example deploy/cloud/oci/ops/oci_access.env
#   chmod 600 deploy/cloud/oci/ops/oci_access.env

# 방법 1) ssh config alias 사용 시
# OCI_REMOTE_SSH_TARGET=coinpilot-oci

# 방법 2) user@host 조합 직접 지정 시
OCI_REMOTE_HOST=168.107.40.180
OCI_REMOTE_USER=ubuntu

# SSH private key (로컬 경로)
OCI_REMOTE_SSH_KEY_PATH=~/.ssh/coinpilot-oci/coinpilot-ins_a1_flex
OCI_REMOTE_SSH_PORT=22

# 운영 repo root on OCI
OCI_REMOTE_REPO_ROOT=/opt/coin-pilot

# SSH safety defaults
OCI_REMOTE_CONNECT_TIMEOUT_SEC=10
OCI_REMOTE_STRICT_HOST_KEY_CHECKING=accept-new

# Browser tunnel local port defaults
OCI_TUNNEL_LOCAL_DASHBOARD_PORT=18501
OCI_TUNNEL_LOCAL_N8N_PORT=15678
OCI_TUNNEL_LOCAL_GRAFANA_PORT=13000
OCI_TUNNEL_LOCAL_PROMETHEUS_PORT=19090

# Browser tunnel remote service ports on OCI
OCI_TUNNEL_REMOTE_DASHBOARD_PORT=8501
OCI_TUNNEL_REMOTE_N8N_PORT=5678
OCI_TUNNEL_REMOTE_GRAFANA_PORT=3000
OCI_TUNNEL_REMOTE_PROMETHEUS_PORT=9090
